            "body": {
              "mode": "raw",
              "raw": "{\n    \"eSim\": {\n        \"region_type\": \"local\", //local , global , (europe/asia/...) , all (cannot be blank)\n        \"country_code\": \"BD\", // will work for region_type:local only\n        \"plan_type\": \"data\",\n        \"topup_included\": \"yes\"\n    },\n    \"supplier_uid\": \"all\", //all\n    \"partner_id\": \"1\", //ftm_partner_id / mark blank\n    \"short_ref\": \"xxxx111\", //optional for stream search\n    \"language\": \"en\"\n}",
              "options": {
